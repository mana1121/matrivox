# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# --- Anthropic (optional). If missing, classifier falls back to keyword rules. ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- WhatsApp provider abstraction. Use "demo" for the prototype. ---
# Supported: demo | twilio | meta
WHATSAPP_PROVIDER=demo

# Twilio (only if WHATSAPP_PROVIDER=twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=

# Meta WhatsApp Cloud API (only if WHATSAPP_PROVIDER=meta)
META_WA_PHONE_NUMBER_ID=
META_WA_ACCESS_TOKEN=

# Webhook signing secret for inbound messages (any string for demo)
WHATSAPP_WEBHOOK_SECRET=matrivox-demo
